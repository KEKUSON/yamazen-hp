---
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark-accent pt-16 pb-8 relative overflow-hidden" style="border-top: 2px solid rgba(196,163,90,0.4);">
  <!-- Subtle gradient overlay for depth -->
  <div class="absolute top-0 left-0 w-full h-full pointer-events-none" style="background: linear-gradient(135deg, rgba(196,163,90,0.03) 0%, transparent 40%, rgba(74,111,165,0.03) 100%);"></div>
  <div class="max-w-7xl mx-auto px-4 relative z-10">
    <!-- Main grid: 4 columns on desktop -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Column 1: Company info -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={`${base}/`} class="inline-block text-xl font-bold mb-4" aria-label="山全金物設計所 トップへ">
          <span class="gradient-text">山全</span><span class="text-white/90">金物設計所</span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mb-4">
          建築金物施工図の設計・作図を行う専門設計事務所。官公庁施設から集合住宅まで、10年の実績。
        </p>
        <p class="text-gray-600 text-xs">&copy; {currentYear} 山全金物設計所</p>
      </div>

      <!-- Column 2: Navigation -->
      <div>
        <h4 class="text-xs font-bold text-white uppercase tracking-widest mb-4">Navigation</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={`${base}/strength/`} class="text-gray-400 hover:text-metallic-gold transition-colors duration-200">
              山全の強み
            </a>
          </li>
          <li>
            <a href={`${base}/services/`} class="text-gray-400 hover:text-metallic-gold transition-colors duration-200">
              サービス
            </a>
          </li>
          <li class="pl-3 border-l border-gray-700/50">
            <a href={`${base}/services/#handrails`} class="text-gray-500 hover:text-gray-300 text-xs transition-colors duration-200">
              手摺・タラップ
            </a>
          </li>
          <li class="pl-3 border-l border-gray-700/50">
            <a href={`${base}/services/#panels`} class="text-gray-500 hover:text-gray-300 text-xs transition-colors duration-200">
              パネル・三方枠
            </a>
          </li>
          <li class="pl-3 border-l border-gray-700/50">
            <a href={`${base}/services/#special`} class="text-gray-500 hover:text-gray-300 text-xs transition-colors duration-200">
              特殊金物
            </a>
          </li>
          <li>
            <a href={`${base}/portfolio/`} class="text-gray-400 hover:text-metallic-gold transition-colors duration-200">
              作図実績
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Information -->
      <div>
        <h4 class="text-xs font-bold text-white uppercase tracking-widest mb-4">Information</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={`${base}/pricing/`} class="text-gray-400 hover:text-metallic-gold transition-colors duration-200">
              料金
            </a>
          </li>
          <li>
            <a href={`${base}/workflow/`} class="text-gray-400 hover:text-metallic-gold transition-colors duration-200">
              ご依頼の流れ
            </a>
          </li>
          <li>
            <a href={`${base}/about/`} class="text-gray-400 hover:text-metallic-gold transition-colors duration-200">
              会社概要
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h4 class="text-xs font-bold text-white uppercase tracking-widest mb-4">Contact</h4>
        <ul class="space-y-3 text-sm text-gray-400 mb-6">
          <li>
            <a
              href="https://line.me/R/ti/p/@450yisjc"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-[#00B900] transition-colors flex items-center gap-2"
            >
              <!-- LINE icon -->
              <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .629.285.629.63 0 .344-.28.629-.629.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.626 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.915C23.176 14.393 24 12.458 24 10.314"/>
              </svg>
              LINE でお問い合わせ
            </a>
          </li>
          <li>
            <a
              href="mailto:yamazen.ken@gmail.com"
              class="hover:text-steel-blue transition-colors flex items-center gap-2"
            >
              <!-- Email icon -->
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              yamazen.ken@gmail.com
            </a>
          </li>
        </ul>
        <a
          href={`${base}/contact/`}
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-steel-blue hover:bg-steel-light
                 text-white text-sm font-medium rounded shadow-md
                 hover:shadow-steel-blue/30 transition-all duration-300"
        >
          お問い合わせフォーム
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t pt-6" style="border-color: rgba(196,163,90,0.12);">
      <div class="flex flex-col md:flex-row justify-between items-center gap-3">
        <p class="text-gray-500 text-xs">&copy; {currentYear} 山全金物設計所 — 建築金物施工図設計</p>
        <div class="flex items-center gap-3">
          <span class="text-gray-600 text-xs px-2 py-1 border border-gray-700/50 rounded">JWW / AutoCAD 対応</span>
          <span class="text-gray-600 text-xs">建築金物施工図 専門</span>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .bg-steel-blue { background-color: #4a6fa5; }
  .hover\:bg-steel-light:hover { background-color: #6b8fc4; }
  .hover\:text-steel-blue:hover { color: #4a6fa5; }
  .text-metallic-gold { color: #c4a35a; }
  .hover\:text-metallic-gold:hover { color: #c4a35a; }
  .hover\:shadow-steel-blue\/30:hover { box-shadow: 0 4px 16px rgba(74, 111, 165, 0.3); }
</style>
