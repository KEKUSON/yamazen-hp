          <li>
            <a href="mailto:yamazen.ken@gmail.com" class="hover:text-steel-blue transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              yamazen.ken@gmail.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-500 text-sm">&copy; {currentYear} 山全金物設計所 — 建築金物施工図設計</p>
        <p class="text-gray-600 text-xs">JWW / AutoCAD 対応</p>
      </div>
    </div>
  </div>
