---
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark-accent pt-16 pb-8 border-t border-gray-800">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Top row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Column 1: Company -->
      <div>
        <h3 class="text-xl font-bold mb-4">
          <span class="gradient-text">山全</span>金物設計所
        </h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          建築金物施工図の設計・作図を行う専門設計事務所。官公庁施設から集合住宅まで、10年の実績。
        </p>
      </div>

      <!-- Column 2: Services -->
      <div>
        <h4 class="text-sm font-bold text-gray-300 uppercase tracking-wider mb-4">Services</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="#services" class="hover:text-white transition-colors">手摺 / タラップ</a></li>
          <li><a href="#services" class="hover:text-white transition-colors">パネル / 三方枠</a></li>
          <li><a href="#services" class="hover:text-white transition-colors">特殊金物 / 階段</a></li>
          <li><a href="#services" class="hover:text-white transition-colors">カバー / エキスパンション</a></li>
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div>
        <h4 class="text-sm font-bold text-gray-300 uppercase tracking-wider mb-4">Contact</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li>
            <a href="https://line.me/R/ti/p/@450yisjc" target="_blank" rel="noopener noreferrer" class="hover:text-[#00B900] transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .629.285.629.63 0 .344-.28.629-.629.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.626 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.915C23.176 14.393 24 12.458 24 10.314"/></svg>
              LINE でお問い合わせ
