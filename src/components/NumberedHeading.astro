---
interface Props {
  number: number;
  title: string;
  subtitle?: string;
  lightBg?: boolean;
}

const { number, title, subtitle, lightBg = false } = Astro.props;

// Format number as :01, :02, etc.
const formattedNumber = `:${String(number).padStart(2, '0')}`;
---

<div class="numbered-heading reveal">
  <div class="flex items-start gap-4 md:gap-6">
    <!-- Large metallic number with glow -->
    <div class="relative flex-shrink-0 leading-none">
      <div class="number-glow absolute inset-0 -z-10" aria-hidden="true"></div>
      <span class="number-display leading-none" aria-hidden="true">
        {formattedNumber}
      </span>
    </div>

    <!-- Title and subtitle -->
    <div class="pt-2">
      <h2 class={`text-2xl md:text-3xl lg:text-4xl font-bold leading-tight ${lightBg ? '' : 'text-white'}`}
          style={lightBg ? 'color: #1a202c;' : ''}>{title}</h2>
      {subtitle && (
        <p class={`text-sm md:text-base tracking-widest uppercase mt-2 ${lightBg ? '' : 'text-gray-400'}`}
           style={lightBg ? 'color: #6b7280;' : ''}>{subtitle}</p>
      )}
    </div>
  </div>

  <!-- Decorative gold line -->
  <div class="mt-4 h-px w-full" style="background: linear-gradient(90deg, #c4a35a 0%, rgba(196,163,90,0.3) 40%, transparent 100%);"></div>
</div>

<style>
  .number-glow {
    width: 120%;
    height: 120%;
    top: -10%;
    left: -10%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(196,163,90,0.18) 0%, rgba(196,163,90,0.06) 50%, transparent 75%);
    filter: blur(12px);
    pointer-events: none;
  }

  .number-display {
    font-size: clamp(3.5rem, 8vw, 6rem); /* text-7xl equivalent, responsive */
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(135deg, #8a6e35 0%, #c4a35a 40%, #e8c87a 60%, #c4a35a 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer-text 4s linear infinite;
    letter-spacing: -0.02em;
  }

  @keyframes shimmer-text {
    0% { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .number-display {
      animation: none;
      background-position: 0% center;
    }
  }
</style>
