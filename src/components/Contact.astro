<section id="contact" class="py-24 bg-dark-accent reveal">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-metallic-gold">
      お問い合わせ
    </h2>
    <p class="text-center text-gray-400 mb-16">Contact</p>

    <!-- Important notice -->
    <div class="bg-gradient-to-r from-steel-blue/20 to-metallic-gold/20 rounded-xl p-8 mb-12 border border-steel-blue/30">
      <div class="flex items-start gap-4">
        <svg class="w-8 h-8 text-steel-blue flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <p class="text-lg text-white font-medium mb-2">
            海外拠点にて活動しております。
          </p>
          <p class="text-gray-300">
            お打ち合わせはLINE（チャット・通話）・メールで承っております。<br>
            LINEコールでの通話も可能ですので、お気軽にご連絡ください。
          </p>
        </div>
      </div>
    </div>

    <!-- Contact methods -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- LINE -->
      <a href="https://line.me/R/ti/p/@450yisjc" target="_blank" rel="noopener noreferrer" class="block bg-dark-bg rounded-xl p-8 border border-gray-700 hover:border-[#00B900] hover:scale-105 transition-all duration-300 group">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-16 h-16 rounded-full bg-[#00B900]/20 flex items-center justify-center">
            <svg class="w-8 h-8 text-[#00B900]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .629.285.629.63 0 .344-.28.629-.629.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.626 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.915C23.176 14.393 24 12.458 24 10.314"/>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-white group-hover:text-[#00B900] transition-colors">LINE</h3>
            <p class="text-gray-400">チャット・通話でお問い合わせ</p>
          </div>
        </div>
        <p class="text-gray-400 text-sm">LINEコールで通話も可能です（通話料無料）</p>
      </a>

      <!-- Email -->
      <a href="mailto:yamazen.ken@gmail.com" class="block bg-dark-bg rounded-xl p-8 border border-gray-700 hover:border-steel-blue hover:scale-105 transition-all duration-300 group">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-16 h-16 rounded-full bg-steel-blue/20 flex items-center justify-center">
            <svg class="w-8 h-8 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-white group-hover:text-steel-blue transition-colors">メール</h3>
            <p class="text-gray-400">Email</p>
          </div>
        </div>
        <p class="text-gray-400 text-sm">yamazen.ken@gmail.com</p>
      </a>
    </div>
  </div>
</section>
