---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="bg-dark-bg border-b border-gray-800/50" aria-label="パンくずリスト">
  <div class="max-w-7xl mx-auto px-4 py-4">
    <ol class="flex items-center flex-wrap gap-1 text-sm text-gray-400" itemscope itemtype="https://schema.org/BreadcrumbList">
      {items.map((item, index) => (
        <li class="flex items-center gap-1" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          {index > 0 && (
            <svg class="w-3 h-3 text-metallic-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          )}
          {item.href ? (
            <a
              href={item.href}
              class="hover:text-metallic-gold transition-colors duration-200"
              itemprop="item"
            >
              <span itemprop="name">{item.label}</span>
            </a>
          ) : (
            <span class="text-gray-200" itemprop="name" aria-current="page">{item.label}</span>
          )}
          <meta itemprop="position" content={String(index + 1)} />
        </li>
      ))}
    </ol>
  </div>
</nav>
