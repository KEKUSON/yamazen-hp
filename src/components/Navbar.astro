---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

// Helper: is the given path the active page?
function isActive(path: string): boolean {
  // Normalize: strip trailing slash for comparison (but keep root as-is)
  const normalized = path.endsWith('/') && path.length > 1 ? path.slice(0, -1) : path;
  const current = currentPath.endsWith('/') && currentPath.length > 1 ? currentPath.slice(0, -1) : currentPath;
  return current === normalized;
}

// Nav links (href is the full deployed path including base)
const navLinks = [
  { label: '山全の強み', href: `${base}/strength/` },
  { label: 'サービス', href: `${base}/services/`, hasDropdown: true },
  { label: '作図実績', href: `${base}/portfolio/` },
  { label: '料金', href: `${base}/pricing/` },
  { label: 'ご依頼の流れ', href: `${base}/workflow/` },
];

const serviceDropdown = [
  { label: '手摺・タラップ', href: `${base}/services/#handrails` },
  { label: 'パネル・三方枠', href: `${base}/services/#panels` },
  { label: '特殊金物', href: `${base}/services/#special` },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-40 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href={`${base}/`} class="text-lg font-bold tracking-wide shrink-0" aria-label="山全金物設計所 トップへ">
      <span class="gradient-text">山全</span><span class="hidden sm:inline text-white/90">金物設計所</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-5 lg:gap-6">
      {navLinks.map(link => (
        link.hasDropdown ? (
          <div class="relative group">
            <a
              href={link.href}
              class={`nav-link text-sm transition-colors duration-200 flex items-center gap-1 ${isActive(link.href) ? 'active text-metallic-gold' : 'text-gray-300 hover:text-white'}`}
            >
              {link.label}
              <svg class="w-3 h-3 opacity-60 group-hover:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <!-- Dropdown -->
            <div class="nav-dropdown absolute top-full left-1/2 -translate-x-1/2 mt-2 w-44 rounded-lg overflow-hidden
                        opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto
                        transition-all duration-200 translate-y-1 group-hover:translate-y-0">
              <div class="bg-dark-accent border border-gray-700/50 rounded-lg py-1 shadow-xl shadow-black/40">
                {serviceDropdown.map(item => (
                  <a
                    href={item.href}
                    class="block px-4 py-2 text-sm text-gray-300 hover:text-metallic-gold hover:bg-white/5 transition-colors duration-150"
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={`nav-link text-sm transition-colors duration-200 ${isActive(link.href) ? 'active text-metallic-gold' : 'text-gray-300 hover:text-white'}`}
          >
            {link.label}
          </a>
        )
      ))}
      <a
        href={`${base}/contact/`}
        class="ml-2 px-5 py-2 bg-steel-blue hover:bg-steel-light text-white text-sm font-medium rounded
               shadow-md hover:shadow-steel-blue/30 transition-all duration-300"
      >
        お問い合わせ
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden relative w-8 h-8 flex flex-col justify-center items-center gap-[5px]"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="ham-line block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
      <span class="ham-line block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
      <span class="ham-line block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
    </button>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-dark-accent/95 backdrop-blur-lg z-50
         flex flex-col items-center justify-center gap-6
         opacity-0 pointer-events-none
         transition-opacity duration-300"
  aria-hidden="true"
>
  <!-- Close button -->
  <button
    id="menu-close"
    class="absolute top-5 right-5 w-10 h-10 flex items-center justify-center text-gray-400 hover:text-white transition-colors"
    aria-label="メニューを閉じる"
  >
    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <!-- Logo inside overlay -->
  <a href={`${base}/`} class="mobile-nav-link text-2xl font-bold mb-2">
    <span class="gradient-text">山全</span><span class="text-white/90">金物設計所</span>
  </a>

  <nav class="flex flex-col items-center gap-5 w-full px-8" aria-label="モバイルナビゲーション">
    <a href={`${base}/strength/`}  class="mobile-nav-link text-xl font-medium text-gray-300 hover:text-metallic-gold transition-colors duration-200">山全の強み</a>
    <a href={`${base}/services/`}  class="mobile-nav-link text-xl font-medium text-gray-300 hover:text-metallic-gold transition-colors duration-200">サービス</a>
    <!-- Service sub-links on mobile -->
    <div class="flex flex-col items-center gap-2 text-sm border-t border-gray-700/50 pt-3 w-full">
      <a href={`${base}/services/#handrails`} class="mobile-nav-link text-gray-400 hover:text-metallic-gold transition-colors duration-200">手摺・タラップ</a>
      <a href={`${base}/services/#panels`}    class="mobile-nav-link text-gray-400 hover:text-metallic-gold transition-colors duration-200">パネル・三方枠</a>
      <a href={`${base}/services/#special`}   class="mobile-nav-link text-gray-400 hover:text-metallic-gold transition-colors duration-200">特殊金物</a>
    </div>
    <a href={`${base}/portfolio/`} class="mobile-nav-link text-xl font-medium text-gray-300 hover:text-metallic-gold transition-colors duration-200">作図実績</a>
    <a href={`${base}/pricing/`}   class="mobile-nav-link text-xl font-medium text-gray-300 hover:text-metallic-gold transition-colors duration-200">料金</a>
    <a href={`${base}/workflow/`}  class="mobile-nav-link text-xl font-medium text-gray-300 hover:text-metallic-gold transition-colors duration-200">ご依頼の流れ</a>
    <a
      href={`${base}/contact/`}
      class="mobile-nav-link mt-2 px-10 py-3 bg-steel-blue hover:bg-steel-light text-white text-lg font-medium rounded transition-all duration-300"
    >
      お問い合わせ
    </a>
  </nav>
</div>

<style>
  /* Initial state — semi-transparent with subtle blur */
  #navbar {
    background-color: rgba(15, 15, 26, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border-bottom: 1px solid rgba(74, 111, 165, 0.1);
  }

  /* Scrolled state — applied via JS */
  #navbar.scrolled {
    background-color: rgba(15, 15, 26, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(107, 143, 196, 0.25);
    box-shadow: 0 1px 0 rgba(196,163,90,0.3), 0 4px 30px rgba(0,0,0,0.5);
  }

  /* Active nav link (desktop) */
  #navbar .nav-link.active {
    color: #c4a35a;
  }

  /* Active nav link (mobile) */
  #mobile-menu .mobile-nav-link.active {
    color: #c4a35a;
  }

  /* Mobile menu visible state */
  #mobile-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  /* Hamburger → X transformation */
  #menu-toggle.open .ham-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  #menu-toggle.open .ham-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #menu-toggle.open .ham-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Tailwind overrides for nav buttons (needed for SSR) */
  .bg-steel-blue { background-color: #4a6fa5; }
  .hover\:bg-steel-light:hover { background-color: #6b8fc4; }
  .text-metallic-gold { color: #c4a35a; }
</style>

<script>
  (function () {
    const navbar     = document.getElementById('navbar') as HTMLElement;
    const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
    const menuToggle = document.getElementById('menu-toggle') as HTMLButtonElement;
    const menuClose  = document.getElementById('menu-close') as HTMLButtonElement;

    if (!navbar || !mobileMenu || !menuToggle || !menuClose) return;

    // ── 1. Scroll → glass background ──────────────────────────────────────
    let rafScheduled = false;
    let isScrolled   = false;

    function handleScroll() {
      const shouldScroll = window.scrollY > 80;
      if (shouldScroll !== isScrolled) {
        isScrolled = shouldScroll;
        navbar.classList.toggle('scrolled', isScrolled);
      }
      rafScheduled = false;
    }

    window.addEventListener('scroll', () => {
      if (!rafScheduled) {
        rafScheduled = true;
        requestAnimationFrame(handleScroll);
      }
    }, { passive: true });

    // Run once on load in case page is already scrolled
    handleScroll();


    // ── 2. Mobile menu helpers ─────────────────────────────────────────────
    function openMenu() {
      mobileMenu.classList.add('open');
      mobileMenu.setAttribute('aria-hidden', 'false');
      menuToggle.classList.add('open');
      menuToggle.setAttribute('aria-expanded', 'true');
      menuToggle.setAttribute('aria-label', 'メニューを閉じる');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      mobileMenu.classList.remove('open');
      mobileMenu.setAttribute('aria-hidden', 'true');
      menuToggle.classList.remove('open');
      menuToggle.setAttribute('aria-expanded', 'false');
      menuToggle.setAttribute('aria-label', 'メニューを開く');
      document.body.style.overflow = '';
    }

    menuToggle.addEventListener('click', () => {
      if (menuToggle.classList.contains('open')) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    menuClose.addEventListener('click', closeMenu);

    // Close on any mobile link click
    mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuToggle.classList.contains('open')) {
        closeMenu();
        menuToggle.focus();
      }
    });
  })();
</script>
