---
import PageLayout from '../layouts/PageLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="お問い合わせ | 山全金物設計所"
  description="山全金物設計所へのお問い合わせはLINEまたはメールで承っております。LINEコールでの通話も可能です。"
  heroTitle="お問い合わせ"
  heroSubtitle="CONTACT"
  heroBgImage="bg/contact-bg.webp"
  breadcrumb={[
    { label: 'HOME', href: `${base}/` },
    { label: 'お問い合わせ' },
  ]}
>

  <section class="py-20 px-4 relative overflow-hidden" style="background-color: #141428;">
    <!-- Section top gradient line (animated) -->
    <div class="absolute top-0 left-0 right-0 section-topline"></div>
    <div class="absolute top-0 left-0 w-1/2 h-1/2 pointer-events-none" style="background: radial-gradient(ellipse at top left, rgba(196,163,90,0.04) 0%, transparent 65%);"></div>
    <div class="absolute bottom-0 right-0 w-1/2 h-1/2 pointer-events-none" style="background: radial-gradient(ellipse at bottom right, rgba(74,111,165,0.05) 0%, transparent 65%);"></div>
    <div class="max-w-4xl mx-auto space-y-12 relative z-10">

      <!-- ===== Notice Banner ===== -->
      <div class="reveal">
        <div class="notice-banner rounded-xl p-6 md:p-8 flex gap-4 items-start">
          <!-- Info icon -->
          <div class="notice-icon-circle flex-shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <p class="text-gray-200 text-sm md:text-base leading-loose">
            海外拠点にて活動しております。お打ち合わせはLINE（チャット・通話）・メールで承っております。LINEコールでの通話も可能ですので、お気軽にご連絡ください。
          </p>
        </div>
      </div>

      <!-- ===== Contact Cards ===== -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal-stagger">

        <!-- LINE Card -->
        <a
          href="https://line.me/R/ti/p/@450yisjc"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card contact-card-line rounded-xl p-8 flex flex-col items-center text-center group"
          aria-label="LINEでお問い合わせ（新しいタブで開きます）"
        >
          <!-- Icon circle -->
          <div class="contact-icon-circle contact-icon-line mb-6">
            <svg class="w-10 h-10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .629.285.629.63 0 .344-.28.629-.629.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.626 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.915C23.176 14.393 24 12.458 24 10.314"/>
            </svg>
          </div>

          <h3 class="text-xl font-bold text-white mb-1">LINE</h3>
          <p class="text-gray-400 text-sm mb-4">チャット・通話でお問い合わせ</p>
          <p class="text-sm text-gray-300 mb-6">LINEコールで通話も可能です（通話料無料）</p>

          <span class="contact-cta-btn contact-cta-btn-line">
            LINEで連絡する
            <svg class="w-4 h-4 inline-block ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </span>
        </a>

        <!-- Email Card -->
        <a
          href="mailto:yamazen.ken@gmail.com"
          class="contact-card contact-card-email rounded-xl p-8 flex flex-col items-center text-center group"
          aria-label="メールでお問い合わせ"
        >
          <!-- Icon circle -->
          <div class="contact-icon-circle contact-icon-email mb-6">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>

          <h3 class="text-xl font-bold text-white mb-1">メール</h3>
          <p class="text-gray-400 text-sm mb-4">Email</p>
          <p class="text-sm text-gray-300 mb-6 font-mono tracking-wide">yamazen.ken@gmail.com</p>

          <span class="contact-cta-btn contact-cta-btn-email">
            メールを送る
            <svg class="w-4 h-4 inline-block ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>

      <!-- ===== Response Note ===== -->
      <div class="reveal text-center">
        <p class="inline-flex items-center gap-2 text-gray-400 text-sm">
          <!-- Clock icon -->
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          通常24時間以内にご返信いたします
        </p>
      </div>

    </div>
  </section>

</PageLayout>

<style>
  /* Notice banner */
  .notice-banner {
    background-color: #1e1e3c;
    border: 1px solid rgba(74, 111, 165, 0.35);
    border-left: 4px solid #c4a35a;
    box-shadow: 0 2px 12px rgba(0,0,0,0.4);
    position: relative;
  }


  .notice-icon-circle {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(196, 163, 90, 0.12);
    border: 1px solid rgba(196, 163, 90, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c4a35a;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Contact cards */
  .contact-card {
    background-color: #1e1e3c;
    border: 1px solid rgba(74, 111, 165, 0.25);
    border-left: 4px solid #c4a35a;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    text-decoration: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .contact-card:hover {
    transform: translateY(-4px);
  }

  .contact-card-line:hover {
    border-color: #00B900;
    box-shadow: 0 12px 40px rgba(0, 185, 0, 0.3), 0 0 30px rgba(0, 185, 0, 0.12);
  }

  .contact-card-email:hover {
    border-color: #4a6fa5;
    box-shadow: 0 12px 40px rgba(74, 111, 165, 0.35), 0 0 30px rgba(74, 111, 165, 0.12);
  }

  /* Icon circles */
  .contact-icon-circle {
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .contact-icon-line {
    background: rgba(0, 185, 0, 0.15);
    color: #00B900;
    border: 1px solid rgba(0, 185, 0, 0.3);
    box-shadow: 0 0 20px rgba(0, 185, 0, 0.12);
  }

  .contact-card-line:hover .contact-icon-line {
    background: rgba(0, 185, 0, 0.25);
    box-shadow: 0 0 30px rgba(0, 185, 0, 0.28);
  }

  .contact-icon-email {
    background: rgba(74, 111, 165, 0.15);
    color: #6b8fc4;
    border: 1px solid rgba(74, 111, 165, 0.3);
    box-shadow: 0 0 20px rgba(74, 111, 165, 0.12);
  }

  .contact-card-email:hover .contact-icon-email {
    background: rgba(74, 111, 165, 0.28);
    box-shadow: 0 0 30px rgba(74, 111, 165, 0.28);
  }

  /* CTA buttons inside cards */
  .contact-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.6rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  .contact-cta-btn-line {
    background: #00B900;
    color: #fff;
  }

  .contact-card-line:hover .contact-cta-btn-line {
    opacity: 0.9;
  }

  .contact-cta-btn-email {
    background: #4a6fa5;
    color: #fff;
  }

  .contact-card-email:hover .contact-cta-btn-email {
    opacity: 0.9;
  }
</style>
