---
import PageLayout from '../layouts/PageLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTABanner from '../components/CTABanner.astro';

const base = import.meta.env.BASE_URL;

const steps = [
  {
    number: '01',
    title: 'お問い合わせ',
    description: 'LINE または メールでご連絡ください。図面の概要・物量・納期の目安をお伝えいただけるとスムーズです。',
    icon: 'contact',
  },
  {
    number: '02',
    title: 'お打ち合わせ',
    description: '図面の内容・仕様・納期を確認いたします。LINEチャットまたはLINEコールで対応可能です。',
    icon: 'meeting',
  },
  {
    number: '03',
    title: 'お見積り',
    description: '物量・仕様に応じたお見積りを提出いたします。お見積りは無料です。ご確認後、ご発注をお願いします。',
    icon: 'estimate',
  },
  {
    number: '04',
    title: '作図',
    description: 'CAD（JWW / AutoCAD）にて施工図を作成いたします。精度を重視しながら、納期を厳守します。',
    icon: 'drawing',
  },
  {
    number: '05',
    title: 'チェックバック',
    description: '完成図をご確認いただき、修正点があれば対応いたします。お客様にご満足いただけるまで丁寧に対応します。',
    icon: 'check',
  },
  {
    number: '06',
    title: '納品',
    description: 'PDF + CADデータ（JWW / DWG）にて納品いたします。ご希望のファイル形式がある場合はご相談ください。',
    icon: 'delivery',
  },
];
---

<PageLayout
  title="ご依頼の流れ | 山全金物設計所"
  description="山全金物設計所へのご依頼の流れ。お問い合わせから納品まで6ステップ。PDF・CADデータで納品。"
  heroTitle="ご依頼の流れ"
  heroSubtitle="WORKFLOW"
  heroBgImage="bg/workflow-bg.webp"
  breadcrumb={[
    { label: 'HOME', href: `${base}/` },
    { label: 'ご依頼の流れ' },
  ]}
>

  <!-- ===== Timeline Section ===== -->
  <section class="py-20 px-4 relative overflow-hidden" style="background-color: #141428;">
    <!-- Section top gradient line (animated) -->
    <div class="absolute top-0 left-0 right-0 section-topline"></div>
    <div class="absolute top-0 left-0 w-1/2 h-1/2 pointer-events-none" style="background: radial-gradient(ellipse at top left, rgba(196,163,90,0.05) 0%, transparent 65%);"></div>
    <div class="absolute bottom-0 right-0 w-1/3 h-1/3 pointer-events-none" style="background: radial-gradient(ellipse at bottom right, rgba(74,111,165,0.05) 0%, transparent 65%);"></div>
    <div class="max-w-3xl mx-auto relative z-10">

      <div class="timeline reveal-stagger" id="workflow-timeline">
        {steps.map((step, i) => (
          <div class="timeline-item relative">

            <!-- Connector line segment (between steps) -->
            {i < steps.length - 1 && (
              <div class="connector-line" aria-hidden="true"></div>
            )}

            <div class="flex gap-6 md:gap-10 items-start">

              <!-- Step circle -->
              <div class="step-circle-wrap flex-shrink-0">
                <div class="step-circle">
                  <span class="step-number">{step.number}</span>
                </div>
              </div>

              <!-- Content -->
              <div class="step-content-wrapper pb-10">
              <div class="step-content">
                <div class="flex items-center gap-3 mb-3">
                  <!-- Step icon -->
                  <div class="step-icon-wrap" aria-hidden="true">
                    {step.icon === 'contact' && (
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                      </svg>
                    )}
                    {step.icon === 'meeting' && (
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                    )}
                    {step.icon === 'estimate' && (
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                      </svg>
                    )}
                    {step.icon === 'drawing' && (
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                      </svg>
                    )}
                    {step.icon === 'check' && (
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    )}
                    {step.icon === 'delivery' && (
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                      </svg>
                    )}
                  </div>
                  <h3 class="text-lg md:text-xl font-bold text-white">{step.title}</h3>
                </div>
                <p class="text-gray-300 text-sm md:text-base leading-relaxed">
                  {step.description}
                </p>
              </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <SectionDivider direction="right" fromColor="dark-bg" toColor="dark-accent" />

  <!-- CTA -->
  <div class="bg-dark-accent pb-4">
    <CTABanner
      title="まずはお気軽にご連絡ください"
      description="LINEまたはメールで、いつでもお問い合わせを承っております。お見積りは無料です。"
      buttonText="お問い合わせ"
      buttonHref="/contact/"
    />
  </div>

</PageLayout>

<style>
  .timeline {
    position: relative;
  }

  .timeline-item {
    position: relative;
  }

  /* Vertical connector line between steps */
  .connector-line {
    position: absolute;
    left: 2rem; /* center of step-circle (64px wide / 2 = 32px, - 1px) */
    top: 4rem;  /* below circle */
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #c4a35a 0%, #4a6fa5 50%, #c4a35a 100%);
    opacity: 0.55;
    transform-origin: top;
    animation: line-grow 0.8s ease forwards;
    animation-play-state: paused;
    box-shadow: 0 0 8px rgba(196, 163, 90, 0.3);
  }

  .timeline.active .connector-line {
    animation-play-state: running;
  }

  @keyframes line-grow {
    from { transform: scaleY(0); opacity: 0; }
    to   { transform: scaleY(1); opacity: 0.45; }
  }

  .step-circle-wrap {
    width: 4rem;
    height: 4rem;
    position: relative;
    z-index: 2;
  }

  .step-circle {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background-color: #242448;
    border: 2px solid #4a6fa5;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    box-shadow: 0 0 20px rgba(74, 111, 165, 0.4);
  }

  .timeline-item:hover .step-circle {
    border-color: #c4a35a;
    box-shadow: 0 0 28px rgba(196, 163, 90, 0.4);
  }

  .step-number {
    font-size: 1.1rem;
    font-weight: 700;
    background: linear-gradient(135deg, #c4a35a 0%, #e8c87a 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .step-content-wrapper {
    flex: 1;
    min-width: 0;
  }

  .step-content {
    background-color: #242448;
    border: 1px solid rgba(74, 111, 165, 0.25);
    border-left: 4px solid #c4a35a;
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.4);
    margin-bottom: 0.75rem;
  }

  .step-icon-wrap {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    background: rgba(74, 111, 165, 0.15);
    border: 1px solid rgba(74, 111, 165, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b8fc4;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s;
  }

  .timeline-item:hover .step-icon-wrap {
    background: rgba(196, 163, 90, 0.12);
    border-color: rgba(196, 163, 90, 0.35);
    color: #c4a35a;
  }

  /* Mobile: compact spacing */
  @media (max-width: 640px) {
    .connector-line {
      left: 1.9rem;
    }
    .step-content {
      padding-bottom: 2.5rem;
    }
  }
</style>

<script>
  // Trigger connector line animations when timeline enters view
  const timeline = document.getElementById('workflow-timeline');
  if (timeline) {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });
    obs.observe(timeline);
  }
</script>
